cd ~/Desktop/CreditProject

# Update .gitignore
cat > .gitignore << 'EOF'
# Build files
target/classes
target/generated-sources
target/generated-test-sources
target/maven-archiver
target/maven-status
target/surefire-reports
target/test-classes

# IDE
.idea/
*.iml
.vscode/
.DS_Store

# Sensitive files
*.env
.env.*
application-local.properties

# Uploads (don't commit user uploads)
uploads/

# EB files
.elasticbeanstalk/
.ebignore
application.jar

# Maven
.mvn/
mvnw
mvnw.cmd
EOF